node_modules/
frontend/node_modules/
.next/
dist/
coverage/
# Apenas /report na raiz (artefatos do jscpd) — não pegar diretórios `report`
# aninhados em frontend/app/api/ads/[id]/report (BFF route real da Fase 3.4).
/report/
.env

# Cache de fontes de dados externas (gerado por scripts; o .gitkeep mantem o diretorio).
scripts/data/*.json
!scripts/data/.gitkeep

# Worktrees locais do Claude Code — nunca versionar.
# Evita falsos submodules e warnings de git submodule foreach no CI.
.claude/worktrees/
# Permissões/settings do Claude Code são por-máquina, não compartilhar.
.claude/settings.local.json
.claude/scheduled_tasks.lock
