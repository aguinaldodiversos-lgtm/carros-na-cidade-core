{
  "frontendDir": "frontend",
  "backendDir": "src",
  "frontendScanDirs": [
    "frontend/app",
    "frontend/components",
    "frontend/lib",
    "frontend/hooks",
    "frontend/services"
  ],
  "backendScanDirs": [
    "src",
    "scripts"
  ],
  "frontendPublicDir": "frontend/public",
  "allowMissingFrontendRoutes": [
    "/login",
    "/planos",
    "/contato",
    "/sobre",
    "/favoritos",
    "/politica-de-privacidade",
    "/termos-de-uso",
    "/lgpd"
  ],
  "knownFrontendSelfLinkingComponents": [
    "@/components/buy/CatalogVehicleCard",
    "@/components/ads/AdCard"
  ],
  "envFiles": [
    ".env",
    ".env.example",
    "frontend/.env",
    "frontend/.env.local",
    "frontend/.env.example"
  ],
  "frontendApiBaseEnvNames": [
    "NEXT_PUBLIC_API_URL",
    "API_URL"
  ],
  "backendApiBaseEnvNames": [
    "API_URL",
    "PORT"
  ],
  "contractHints": [
    {
      "frontendPath": "/content/public/blog-page",
      "methods": ["GET"],
      "backendPattern": "/content/public/blog-page"
    },
    {
      "frontendPath": "/ads/:param",
      "methods": ["GET"],
      "backendPattern": "/ads/:param"
    },
    {
      "frontendPath": "/public/ads/:param",
      "methods": ["GET"],
      "backendPattern": "/public/ads/:param"
    },
    {
      "frontendPath": "/public/listings/:param",
      "methods": ["GET"],
      "backendPattern": "/public/listings/:param"
    },
    {
      "frontendPath": "/catalog/ads/:param",
      "methods": ["GET"],
      "backendPattern": "/catalog/ads/:param"
    },
    {
      "frontendPath": "/api/ads/:param",
      "methods": ["GET"],
      "backendPattern": "/api/ads/:param"
    }
  ]
}
