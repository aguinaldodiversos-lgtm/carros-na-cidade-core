{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "cwd": "./frontend"
    },
    {
      "name": "frontend-dev-regional",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "cwd": "./frontend",
      "env": {
        "REGIONAL_PAGE_ENABLED": "true",
        "REGIONAL_PAGE_CANONICAL_SELF": "true",
        "REGIONAL_BFF_USE_PUBLIC": "true"
      }
    }
  ]
}
