{
  "name": "carros-na-cidade-core",
  "version": "2.0.3",
  "description": "Backend do portal Carros na Cidade - Arquitetura SaaS",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node src/index.js",
    "workers": "node src/workers/bootstrap.js",
    "lint": "eslint src --ext .js",
    "test": "vitest run",
    "smoke": "node scripts/smoke.mjs",
    "smoke:prod": "node scripts/smoke.mjs",
    "smoke:local": "node scripts/smoke.mjs",
    "audit:project": "node ./scripts/project-audit.mjs",
    "audit:project:strict": "node ./scripts/project-audit.mjs --strict",
    "audit:project:json": "node ./scripts/project-audit.mjs --json",
    "audit:links": "node ./scripts/project-audit.mjs --scope=links",
    "audit:assets": "node ./scripts/project-audit.mjs --scope=assets",
    "audit:routes": "node ./scripts/project-audit.mjs --scope=routes",
    "audit:env": "node ./scripts/project-audit.mjs --scope=env",
    "audit:integration": "node ./scripts/project-audit.mjs --scope=integration",
    "audit:jsx-ts": "node ./scripts/project-audit.mjs --scope=jsx-ts"
  },
  "engines": {
    "node": ">=20 <21"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.70.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.2.1",
    "google-auth-library": "^9.4.1",
    "googleapis": "^171.4.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.9.3",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.1.0",
    "mercadopago": "^1.5.17",
    "pg": "^8.11.5",
    "pino": "^9.14.0",
    "pino-pretty": "^11.3.0",
    "resend": "^3.2.0",
    "uuid": "^9.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "vitest": "^2.1.0"
  }
}
