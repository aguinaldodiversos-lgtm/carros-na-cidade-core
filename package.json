{
  "name": "carros-na-cidade-core",
  "version": "2.1.0",
  "description": "Backend do portal Carros na Cidade - Arquitetura SaaS",
  "private": true,
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node src/index.js",
    "dev:debug": "node --inspect src/index.js",
    "workers": "node src/workers/bootstrap.js",
    "workers:debug": "node --inspect src/workers/bootstrap.js",
    "lint": "eslint src scripts --ext .js,.mjs",
    "lint:fix": "eslint src scripts --ext .js,.mjs --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit:deps": "npm audit --audit-level=high",
    "test": "vitest run --exclude \"tests/integration/**\"",
    "test:coverage": "vitest run --exclude \"tests/integration/**\" --coverage",
    "integration:db:up": "docker compose -f docker-compose.test.yml up -d",
    "integration:db:down": "docker compose -f docker-compose.test.yml down",
    "integration:db:wait": "node scripts/wait-for-postgres.mjs",
    "integration:db:prepare": "node scripts/integration-db-prepare.mjs",
    "test:integration:migrations": "vitest run tests/integration/migrations-compat.integration.test.js",
    "test:integration:ads": "node scripts/run-integration-ads-tests.mjs",
    "test:integration:ads:full": "npm run integration:db:up && npm run integration:db:wait && npm run integration:db:prepare && npm run test:integration:ads",
    "ci:integration-ads": "npm run integration:db:wait && npm run integration:db:prepare && npm run test:integration:ads",
    "test:pg-contract": "node scripts/run-pg-fuel-contract.mjs",
    "db:check-ads": "node scripts/print-ads-constraints.js",
    "db:print-checks": "node scripts/print-ads-constraints.js",
    "test:watch": "vitest",
    "db:migrate": "node scripts/run-migrations.mjs",
    "seed:cities": "node scripts/seed-ibge-municipios.mjs",
    "import:cities": "node scripts/import-ibge-cities.js",
    "create:test-ad": "node scripts/create-test-ad.mjs",
    "sanitize:ad-images": "node scripts/sanitize-ad-images.mjs",
    "migrate:legacy-ad-images": "node scripts/migrate-legacy-ad-images-to-r2.mjs",
    "cleanup:orphan-test-ads": "node scripts/cleanup-orphan-test-ads.mjs",
    "smoke": "node scripts/smoke.mjs",
    "smoke:prod": "node scripts/smoke.mjs",
    "smoke:local": "node scripts/smoke.mjs",
    "smoke:publish-upload": "node scripts/smoke-publish-upload.mjs",
    "audit:project": "node ./scripts/project-audit.mjs",
    "audit:project:strict": "node ./scripts/project-audit.mjs --strict",
    "audit:project:json": "node ./scripts/project-audit.mjs --json",
    "audit:links": "node ./scripts/project-audit.mjs --scope=links",
    "audit:assets": "node ./scripts/project-audit.mjs --scope=assets",
    "audit:routes": "node ./scripts/project-audit.mjs --scope=routes",
    "audit:env": "node ./scripts/project-audit.mjs --scope=env",
    "audit:integration": "node ./scripts/project-audit.mjs --scope=integration",
    "audit:contract": "node ./scripts/project-audit.mjs --scope=integration",
    "audit:jsx-ts": "node ./scripts/project-audit.mjs --scope=jsx-ts",
    "env:keys": "node scripts/list-env-keys.mjs",
    "audit:integrity": "node scripts/system-integrity-scan.mjs",
    "audit:clones": "jscpd src frontend --config .jscpd.json",
    "audit:system": "npm run audit:integrity && npm run audit:clones",
    "check": "npm run lint && npm run test",
    "verify": "npm run check && npm run audit:project",
    "test:e2e": "npm run test:e2e --prefix frontend",
    "test:e2e:main": "npm run test:e2e:main --prefix frontend",
    "test:e2e:dashboard": "npm run test:e2e:dashboard --prefix frontend",
    "e2e": "npm run test:e2e --prefix frontend",
    "e2e:smoke": "npm run test:e2e:smoke --prefix frontend",
    "e2e:full-flow": "npm run test:e2e:full-flow --prefix frontend",
    "e2e:prepare": "npm run integration:db:up && npm run integration:db:wait && npm run integration:db:prepare && node scripts/e2e-seed.mjs",
    "test:frontend": "npm run test --prefix frontend",
    "test:frontend:coverage": "npm run test:coverage --prefix frontend"
  },
  "engines": {
    "node": ">=20 <21"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "axios": "^1.6.7",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.70.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "google-auth-library": "^9.4.1",
    "googleapis": "^171.4.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.9.3",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.1.0",
    "mercadopago": "^1.5.17",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.5",
    "pino": "^9.14.0",
    "pino-pretty": "^11.3.0",
    "resend": "^3.2.0",
    "sharp": "^0.34.5",
    "uuid": "^9.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^8.57.0",
    "jscpd": "^3.5.10",
    "prettier": "^3.4.2",
    "supertest": "^7.2.2",
    "vitest": "^2.1.0"
  }
}
