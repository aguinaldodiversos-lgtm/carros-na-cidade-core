# ─────────────────────────────────────────────────────────────────────────────
# .env.test — Variáveis de ambiente para testes E2E (Playwright / full-flow)
# Copie este arquivo e preencha com valores reais; não comite credenciais reais.
# ─────────────────────────────────────────────────────────────────────────────

# URL base do Next.js (frontend) em modo dev
BASE_URL=http://127.0.0.1:3000
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000

# URL base da API Express (backend)
E2E_BACKEND_API_URL=http://127.0.0.1:4000
BACKEND_API_URL=http://127.0.0.1:4000
NEXT_PUBLIC_API_URL=http://127.0.0.1:4000

# Usuário A — deve existir no banco de dados de teste antes de rodar os E2Es.
# Criar com: node scripts/e2e-seed.mjs  (ou npm run e2e:prepare na raiz)
TEST_USER_A_EMAIL=testa@carrosnacidade.com
TEST_USER_A_PASS=SenhaTesteA123!

# Usuário B — usado nos testes de isolamento (Suite 2).
TEST_USER_B_EMAIL=testb@carrosnacidade.com
TEST_USER_B_PASS=SenhaTesteB123!

# (Opcional) Conexão direta ao Postgres de testes para asserções SQL
# E2E_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/carros_na_cidade_test

# (Opcional) FIPE — necessário apenas para Suite 4 (wizard completo)
# FIPE_API_BASE_URL=https://parallelum.com.br/fipe/api/v1
