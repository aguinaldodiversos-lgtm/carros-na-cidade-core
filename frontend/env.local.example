# Copie para .env.local na pasta frontend (arquivos .env* não são commitados).
# Mesmas chaves usadas no Render (carros-na-cidade-portal) — veja painel Environment.

# API core (todas apontam para o mesmo host; getBackendApiBaseUrl aceita qualquer uma)
AUTH_API_BASE_URL=https://carros-na-cidade-core.onrender.com
BACKEND_API_URL=https://carros-na-cidade-core.onrender.com
API_URL=https://carros-na-cidade-core.onrender.com
NEXT_PUBLIC_API_URL=https://carros-na-cidade-core.onrender.com

# Site (local: dev server; produção: URL do portal)
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000

# FIPE (pública Parallelum; igual ao Render)
FIPE_API_BASE_URL=https://parallelum.com.br/fipe/api/v1

NODE_ENV=development
