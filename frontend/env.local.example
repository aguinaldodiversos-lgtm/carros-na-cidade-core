# Copie para .env.local na pasta frontend (arquivos .env* não são commitados).
# Mesmas chaves usadas no Render (carros-na-cidade-portal) — veja painel Environment.

# API core publica (todas apontam para o mesmo host; getBackendApiBaseUrl aceita qualquer uma)
AUTH_API_BASE_URL=https://carros-na-cidade-core.onrender.com
BACKEND_API_URL=https://carros-na-cidade-core.onrender.com
API_URL=https://carros-na-cidade-core.onrender.com
NEXT_PUBLIC_API_URL=https://carros-na-cidade-core.onrender.com

# Private Network do Render (SERVER-ONLY — nunca prefixar NEXT_PUBLIC_*).
# Quando configurada, todo fetch SSR/BFF resolve via essa URL em vez do
# origin publico. Reduz outbound bandwidth (trafego entre services nao
# conta para a quota publica) e latencia. Veja o painel do Render:
#   Service > Settings > "Private network" → hostname interno do backend.
# Geralmente algo como `<service-name>.internal` ou similar — NAO assuma
# formato sem confirmar.
# INTERNAL_BACKEND_API_URL=http://carros-na-cidade-core.internal:4000
# BACKEND_INTERNAL_URL=  # alias aceito; setar so uma

# Token de autenticacao interna entre frontend e backend (SERVER-ONLY).
# Deve ser identico ao INTERNAL_API_TOKEN no backend. Em prod, todo fetch
# SSR/BFF envia esse token no header X-Internal-Token + UA cnc-internal/1.0.
# Sem ele, o backend pode 429 o frontend quando BAD_BOTS_BLOCKED=true.
INTERNAL_API_TOKEN=

# Site (local: dev server; produção: URL do portal)
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000

# FIPE (pública Parallelum; igual ao Render)
FIPE_API_BASE_URL=https://parallelum.com.br/fipe/api/v1

NODE_ENV=development
