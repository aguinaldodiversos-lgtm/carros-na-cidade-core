{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "node ./scripts/prepare-standalone.mjs && node ./scripts/verify-standalone.mjs",
    "start": "node .next/standalone/server.js",
    "lint": "next lint --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepare:standalone": "node ./scripts/prepare-standalone.mjs",
    "verify:standalone": "node ./scripts/verify-standalone.mjs",
    "test:e2e": "playwright test",
    "test:e2e:main": "playwright test e2e/main-flow.spec.ts",
    "test:e2e:publish": "playwright test e2e/10-login-ad-publish.spec.ts",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "autoprefixer": "^10.4.27",
    "embla-carousel-react": "^8.6.0",
    "ioredis": "^5.9.3",
    "next": "14.2.35",
    "postcss": "^8.5.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^20.19.9",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.35",
    "pg": "^8.20.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  }
}
