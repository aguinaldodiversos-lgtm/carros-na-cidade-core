{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "node ./scripts/prepare-standalone.mjs && node ./scripts/verify-standalone.mjs",
    "start": "node .next/standalone/server.js",
    "lint": "next lint --max-warnings 0",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepare:standalone": "node ./scripts/prepare-standalone.mjs",
    "verify:standalone": "node ./scripts/verify-standalone.mjs",
    "test:e2e": "playwright test",
    "test:e2e:main": "playwright test e2e/main-flow.spec.ts",
    "test:e2e:dashboard": "playwright test e2e/dashboard-login-pf-pj.spec.ts",
    "test:e2e:smoke": "playwright test --grep \"@smoke\"",
    "test:e2e:publish": "playwright test e2e/10-login-ad-publish.spec.ts",
    "test:e2e:register-publish": "playwright test e2e/register-minimal-to-publish.spec.ts",
    "test:e2e:publish-surface": "playwright test e2e/publish-full-surface.spec.ts",
    "test:e2e:isolation": "playwright test e2e/user-isolation-api.spec.ts",
    "test:e2e:full-flow": "playwright test e2e/full-flow.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:seo": "playwright test --grep \"@seo-canonical|@seo-jsonld|@seo-sitemap\"",
    "test:e2e:seo:canonical": "playwright test e2e/seo-canonical.spec.ts",
    "test:e2e:seo:jsonld": "playwright test e2e/seo-jsonld.spec.ts",
    "test:e2e:seo:sitemap": "playwright test e2e/seo-sitemap.spec.ts",
    "e2e:mock-backend": "npx tsx e2e/mock-backend/server.ts",
    "test:e2e:mock": "E2E_MOCK_BACKEND=1 E2E_BACKEND_API_URL=http://127.0.0.1:4000 playwright test",
    "snapshot:public-routes": "node ./scripts/snapshot-public-routes.mjs",
    "snapshot:diff": "node ./scripts/snapshot-diff.mjs",
    "lint:public-fetch": "node ./scripts/lint-public-fetch.mjs",
    "lint:services-imports": "node ./scripts/lint-services-imports.mjs --baseline=tests/snapshots/services-imports-baseline.txt",
    "lint:services-imports:strict": "node ./scripts/lint-services-imports.mjs --strict",
    "lint:images": "node ./scripts/lint-images-sizes.mjs",
    "lint:images:strict": "node ./scripts/lint-images-sizes.mjs --strict",
    "lint:guardrails": "npm run lint:public-fetch && npm run lint:services-imports && npm run lint:images",
    "test:e2e:images": "playwright test --grep \"@img-fallback\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1028.0",
    "autoprefixer": "^10.4.27",
    "embla-carousel-react": "^8.6.0",
    "ioredis": "^5.9.3",
    "next": "14.2.35",
    "postcss": "^8.5.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.35",
    "jsdom": "^29.0.2",
    "pg": "^8.20.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  }
}
