# Server
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# Database (obrigatório para backend)
DATABASE_URL=postgresql://user:password@localhost:5432/carros_na_cidade

# --- Testes de integração (Vitest + Docker, opcional) ---
# Não copie para .env se não for rodar a suíte; o `npm test` padrão já exclui tests/integration/.
# URL alinhada a docker-compose.test.yml (Postgres na porta host 5433):
# TEST_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/carros_na_cidade_test
# Desliga a suíte ao rodar `vitest` manualmente em todos os arquivos (raro):
# SKIP_INTEGRATION_ADS=1

# Bloco opcional em tests/ads/fuel-transmission-contract.test.js (CHECK no Postgres):
# npm run test:pg-contract  (ou RUN_PG_ADS_CHECK_TESTS=1)
# SKIP_PG_INTEGRATION_TESTS=1  desliga esse bloco mesmo com RUN_PG=1

# Pool PostgreSQL (opcional)
PG_POOL_MAX=20
PG_IDLE_TIMEOUT_MS=30000
PG_CONN_TIMEOUT_MS=10000
PG_SLOW_QUERY_MS=800
# Em produção, use true (padrão). Só use false para DBs com certificado auto-assinado.
PG_SSL_REJECT_UNAUTHORIZED=true

# Redis (opcional para filas/cache)
REDIS_URL=redis://localhost:6379

# JWT (obrigatório para auth)
JWT_SECRET=seu-jwt-secret-aqui
JWT_REFRESH_SECRET=seu-refresh-secret-aqui

# Frontend / FIPE
FIPE_API_KEY=SUA_CHAVE_AQUI

# Frontend Next.js — redes sociais (opcional). Se vazias, o rodapé não exibe links genéricos.
# NEXT_PUBLIC_SOCIAL_INSTAGRAM_URL=https://www.instagram.com/seu_perfil
# NEXT_PUBLIC_SOCIAL_FACEBOOK_URL=https://www.facebook.com/seu_perfil
# NEXT_PUBLIC_SOCIAL_LINKEDIN_URL=https://www.linkedin.com/company/seu-perfil

# Smoke tests
BASE_URL=http://localhost:4000
SMOKE_TIMEOUT_MS=8000
