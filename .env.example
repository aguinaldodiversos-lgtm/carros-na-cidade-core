# ==============================================================================
# CARROS NA CIDADE — .env.example (raiz do monorepo)
# Uso:
# - copie para .env localmente e ajuste os segredos/URLs reais
# - no Render, configure os valores reais no serviço correspondente
# - valores marcados como placeholder DEVEM ser trocados em produção
# ==============================================================================

# ------------------------------------------------------------------------------
# Server / aplicação
# ------------------------------------------------------------------------------
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
SERVICE_NAME=carros-na-cidade-core
APP_NAME=Carros na Cidade
INSTANCE_ID=local-dev
LOG_LEVEL=info
CI=false
GIT_COMMIT=local
RENDER_GIT_COMMIT=local

# ------------------------------------------------------------------------------
# URLs principais — defaults locais
# ------------------------------------------------------------------------------
APP_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
SITE_URL=http://localhost:3000
PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

API_URL=http://localhost:4000
AUTH_API_BASE_URL=http://localhost:4000
BACKEND_API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
BASE_URL=http://localhost:4000

# ------------------------------------------------------------------------------
# Banco de dados — backend
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/carros_na_cidade

# Testes de integração / E2E
TEST_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/carros_na_cidade_test
E2E_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/carros_na_cidade_test
INTEGRATION_PG_WAIT_ATTEMPTS=30
INTEGRATION_PG_WAIT_MS=2000

# Pool PostgreSQL
PG_POOL_MAX=20
PG_IDLE_TIMEOUT_MS=30000
PG_CONN_TIMEOUT_MS=10000
PG_SLOW_QUERY_MS=800

# SSL do Postgres
# Em produção normalmente fica true.
# Em CI/local com Postgres sem SSL, o código atual já sabe desligar quando apropriado.
PG_SSL_REJECT_UNAUTHORIZED=true

# ------------------------------------------------------------------------------
# Migrations / boot
# ------------------------------------------------------------------------------
RUN_MIGRATIONS=true
RUN_WORKERS=false
SHUTDOWN_TIMEOUT_MS=10000

# ------------------------------------------------------------------------------
# Redis / filas / cache
# ------------------------------------------------------------------------------
# Para desenvolvimento sem Redis, deixe DISABLE_REDIS=true
DISABLE_REDIS=true
REDIS_URL=redis://127.0.0.1:6379

# ------------------------------------------------------------------------------
# Auth / sessão / segurança
# ------------------------------------------------------------------------------
JWT_SECRET=troque-por-um-jwt-secret-longo-e-aleatorio
JWT_REFRESH_SECRET=troque-por-um-refresh-secret-longo-e-aleatorio
JWT_AUDIENCE=carros-na-cidade
JWT_ISSUER=carros-na-cidade-core
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=30
REFRESH_TOKEN_PEPPER=troque-por-um-refresh-token-pepper-longo
BCRYPT_SALT_ROUNDS=10

# Necessário para cookies de sessão do frontend/BFF
AUTH_SESSION_SECRET=troque-por-um-segredo-longo-e-aleatorio

# Reset de senha
PASSWORD_RESET_TOKEN_BYTES=32
PASSWORD_RESET_TOKEN_TTL_MIN=60

# ------------------------------------------------------------------------------
# Limites / middlewares / observabilidade
# ------------------------------------------------------------------------------
JSON_BODY_LIMIT=2mb
URLENCODED_BODY_LIMIT=2mb
RATE_LIMIT_GLOBAL_MAX=1000
METRICS_IGNORE_PATHS=/health,/metrics,/favicon.ico
REQUEST_AUDIT_LOGS_ENABLED=false

# ------------------------------------------------------------------------------
# Uploads legados / compatibilidade
# ------------------------------------------------------------------------------
UPLOADS_ROOT=uploads
SERVE_UPLOADS_STATIC=true
PUBLIC_EMIT_LEGACY_IMAGE_PROXY=false

# ------------------------------------------------------------------------------
# Storage / R2
# ------------------------------------------------------------------------------
VEHICLE_IMAGE_MAX_FILE_SIZE_BYTES=7340032
VEHICLE_IMAGE_MAX_FILES=20
VEHICLE_IMAGE_CACHE_CONTROL=public, max-age=31536000, immutable

# Endpoint S3 compatível do Cloudflare R2
R2_ENDPOINT=https://SEU_ACCOUNT_ID.r2.cloudflarestorage.com
AWS_REGION=auto

# Credenciais R2 (substituir em produção)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# URL pública do bucket/CDN (quando existir)
R2_PUBLIC_BASE_URL=

# ------------------------------------------------------------------------------
# Frontend / SEO / redes sociais
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SOCIAL_INSTAGRAM_URL=
NEXT_PUBLIC_SOCIAL_FACEBOOK_URL=
NEXT_PUBLIC_SOCIAL_LINKEDIN_URL=

# ------------------------------------------------------------------------------
# FIPE
# ------------------------------------------------------------------------------
FIPE_API_KEY=
FIPE_API_BASE_URL=

# ------------------------------------------------------------------------------
# Mercado Pago / pagamentos
# ------------------------------------------------------------------------------
MP_PUBLIC_KEY=
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# ------------------------------------------------------------------------------
# Resend / e-mail / comunicações
# ------------------------------------------------------------------------------
RESEND_API_KEY=
STRATEGY_EMAIL=
STRATEGY_WHATSAPP=
SOCIAL_WEBHOOK_URL=

# ------------------------------------------------------------------------------
# WhatsApp / Z-API
# ------------------------------------------------------------------------------
WHATSAPP_PROVIDER=mock
WHATSAPP_WORKER_CONCURRENCY=1
DEALER_WHATSAPP_WEBHOOK_SECRET=
ZAPI_API=
ZAPI_CLIENT_TOKEN=

# ------------------------------------------------------------------------------
# Google / GA4 / Places / IBGE
# ------------------------------------------------------------------------------
GA4_PROPERTY_ID=
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACES_QUERIES=concessionaria,revenda de carros,loja de carros
CNPJ_API_BASE=
IBGE_ESTADO_MUNICIPIOS_URL=https://servicodados.ibge.gov.br/api/v1/localidades/estados

# ------------------------------------------------------------------------------
# AI / LLM / semântica
# ------------------------------------------------------------------------------
AI_ENABLED=false
LOCAL_AI_ENABLED=false
PREMIUM_AI_ENABLED=false
ENABLE_BANNER_WORKER=false

AI_MODE=disabled
AI_BUDGET_DAILY_USD=0
AI_PROVIDER_ATTEMPTS=2
AI_PROVIDER_RETRY_DELAY_MS=1000
AI_REQUIRE_PREMIUM_FOR=
AI_WORKER_CONCURRENCY=1

AI_CIRCUIT_FAILURE_THRESHOLD=5
AI_CIRCUIT_OPEN_MS=300000
AI_CIRCUIT_WINDOW_MS=600000

AI_LOCAL_API_KEY=
AI_LOCAL_URL=http://127.0.0.1:11434
AI_LOCAL_TIMEOUT_MS=30000
NEXT_PUBLIC_AI_API_URL=

OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_TIMEOUT_MS=30000
OLLAMA_MODEL=

OPENAI_API_KEY=
OPENAI_MODEL_TEXT=
OPENAI_TIMEOUT_MS=30000

# ------------------------------------------------------------------------------
# Ads / busca / cidades / feature tuning
# ------------------------------------------------------------------------------
CHECK_ADS_STRICT=false
ADS_AUTOCOMPLETE_CACHE_TTL_MS=300000
ADS_FREE_QUERY_CACHE_TTL_MS=300000
CITIES_IBGE_AUTO_SEED=false
CITIES_PANEL_DICTIONARY_CACHE_TTL_MS=300000

# ------------------------------------------------------------------------------
# Autopilot / growth / workers
# ------------------------------------------------------------------------------
AUTOPILOT_ESTOQUE_MINIMO=5
AUTOPILOT_LEAD_META=10
AUTOPILOT_WORKER_INTERVAL_MS=600000

GROWTH_BRAIN_WORKER_INTERVAL_MS=600000
GROWTH_JOBS_BATCH=50
GROWTH_JOBS_LOCK_MINUTES=15

CITY_PERFORMANCE_WORKER_INTERVAL_MS=600000
CITY_PREDICTION_WORKER_INTERVAL_MS=600000
CITY_SCORE_WORKER_INTERVAL_MS=600000
# Token compartilhado para chamadas de servico-a-servico em /api/internal/*.
# Sem este valor configurado, o endpoint /api/internal/regions/* responde 404
# (deliberado para nao revelar a superficie de ataque). Gere um token forte
# (ex.: openssl rand -hex 32) e mantenha-o no secret manager — nunca commit.
INTERNAL_API_TOKEN=

CITY_STAGE_WORKER_INTERVAL_MS=600000

CLUSTER_EXECUTOR_WORKER_INTERVAL_MS=600000
CLUSTER_PLANNER_WORKER_INTERVAL_MS=600000
INTERNAL_LINKING_WORKER_INTERVAL_MS=600000
MARKET_WORKER_INTERVAL_MS=600000
MONEY_PAGES_WORKER_INTERVAL_MS=600000
OPPORTUNITY_WORKER_INTERVAL_MS=600000
PUBLICATION_AUDIT_WORKER_INTERVAL_MS=600000
REFRESH_PLANNER_WORKER_INTERVAL_MS=600000
SEO_PUBLISHING_WORKER_INTERVAL_MS=600000
SEO_QUEUE_WORKER_INTERVAL_MS=600000
SEO_WORKER_INTERVAL_MS=600000
SITEMAP_WORKER_INTERVAL_MS=600000
STRATEGY_WORKER_INTERVAL_MS=600000

# ------------------------------------------------------------------------------
# Dealer acquisition
# ------------------------------------------------------------------------------
DEALER_ACQUISITION_CITIES_PER_RUN=5
DEALER_ACQUISITION_WORKER_INTERVAL_MS=600000
DEALER_GOOGLE_MAX_PLACES_PER_CITY=20

# ------------------------------------------------------------------------------
# CORS
# ------------------------------------------------------------------------------
# Em produção, ajuste para os domínios reais do portal e da API
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:4000

# ------------------------------------------------------------------------------
# Admin / seeds / utilitários
# ------------------------------------------------------------------------------
ADMIN_API_KEY=troque-por-uma-admin-api-key
ADMIN_PHONE=
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=troque-esta-senha
ADMIN_SEED_NAME=Administrador Inicial

# ------------------------------------------------------------------------------
# E2E / Playwright
# ------------------------------------------------------------------------------
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
E2E_BACKEND_API_URL=http://127.0.0.1:4000
E2E_EMAIL=e2e@example.com
E2E_PASSWORD=troque-esta-senha
E2E_PJ_EMAIL=e2e-pj@example.com
E2E_PJ_PASSWORD=troque-esta-senha
PW_START_SERVER=true
PW_REUSE_SERVER=false
SKIP_E2E_MAIN=false
E2E_MOCK_BACKEND=false

# ------------------------------------------------------------------------------
# Testes de integração específicos
# ------------------------------------------------------------------------------
RUN_DB_INTEGRATION_TESTS=false
RUN_INTEGRATION_ADS_TESTS=false
RUN_PG_ADS_CHECK_TESTS=false
SKIP_INTEGRATION_ADS=false
SKIP_PG_INTEGRATION_TESTS=false

# ------------------------------------------------------------------------------
# Smoke tests / migração legacy
# ------------------------------------------------------------------------------
SOURCE_BASE_URL=http://127.0.0.1:4000
SMOKE_API_URL=http://127.0.0.1:4000
SMOKE_UPLOAD_PATH=/api/ads/upload-images
SMOKE_HEALTH_PATH=/health
SMOKE_TIMEOUT_MS=8000
SMOKE_MAX_LATENCY_MS=3000
SMOKE_BURST_COUNT=5
SMOKE_BURST_CONCURRENCY=1
SMOKE_RETRIES=1
SMOKE_METRICS=false
SMOKE_ORIGIN=http://localhost:3000

# Tokens opcionais para smoke local
AUTH_TOKEN=
SMOKE_AUTH=
SMOKE_AUTH_TOKEN=

# ------------------------------------------------------------------------------
# Misc / integrações opcionais
# ------------------------------------------------------------------------------
APP_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
PUBLIC_SITE_URL=http://localhost:3000
SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
AUTH_API_BASE_URL=http://localhost:4000
BACKEND_API_URL=http://localhost:4000
API_URL=http://localhost:4000

# ------------------------------------------------------------------------------
# Feature flags — referência rápida
# ------------------------------------------------------------------------------
# AI_ENABLED=false
# LOCAL_AI_ENABLED=false
# PREMIUM_AI_ENABLED=false
# ENABLE_BANNER_WORKER=false
# PUBLIC_EMIT_LEGACY_IMAGE_PROXY=false
# REQUEST_AUDIT_LOGS_ENABLED=false
# SERVE_UPLOADS_STATIC=true
# DISABLE_REDIS=true
# RUN_MIGRATIONS=true
# RUN_WORKERS=false
# E2E_MOCK_BACKEND=false

# ------------------------------------------------------------------------------
# Eventos / Feirão / Banner Regional / Impulsionamento Geolocalizado
# ------------------------------------------------------------------------------
# Produto DORMENTE até portal ter volume + operação comercial madura.
# Ver docs/runbooks/events-feature-shutdown.md para superfície e checklist
# de reativação.
#
# Flags strict: APENAS "true" (lowercase, exato) ativa. "TRUE", "1", "yes"
# e qualquer valor inválido mantém DESLIGADO. Default fechado: ausência da
# var = produto OFF. Não definir nenhuma destas em produção até decisão
# explícita.
#
# NÃO confundir com "Destaque pago" / boost de anúncio (planos Grátis/
# Start/Pro/Destaque) — aquilo NÃO é controlado por estas flags.
#
# EVENTS_ENABLED=false              # master kill-switch (gate de tudo abaixo)
# EVENTS_PUBLIC_ENABLED=false       # plano cnpj-evento-premium em /planos, etc
# EVENTS_CREATION_ENABLED=false     # POST /api/events e similares
# EVENTS_PAYMENTS_ENABLED=false     # checkout do plano de evento
# EVENTS_WORKER_ENABLED=false       # workers scheduler/broadcast/etc
# EVENTS_AI_BANNER_ENABLED=false    # geração de banner via DALL-E (custo OpenAI)