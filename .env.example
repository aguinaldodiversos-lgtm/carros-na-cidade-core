# Server
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# Database (obrigatório para backend)
DATABASE_URL=postgresql://user:password@localhost:5432/carros_na_cidade

# Pool PostgreSQL (opcional)
PG_POOL_MAX=20
PG_IDLE_TIMEOUT_MS=30000
PG_CONN_TIMEOUT_MS=10000
PG_SLOW_QUERY_MS=800
# Em produção, use true (padrão). Só use false para DBs com certificado auto-assinado.
PG_SSL_REJECT_UNAUTHORIZED=true

# Redis (opcional para filas/cache)
REDIS_URL=redis://localhost:6379

# JWT (obrigatório para auth)
JWT_SECRET=seu-jwt-secret-aqui
JWT_REFRESH_SECRET=seu-refresh-secret-aqui

# Frontend / FIPE
FIPE_API_KEY=SUA_CHAVE_AQUI

# Smoke tests
BASE_URL=http://localhost:4000
SMOKE_TIMEOUT_MS=8000
