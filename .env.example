# ==============================================================================
# FEATURE FLAGS — referência central
# Detalhes: src/shared/config/features.js (backend), frontend/lib/config/feature-flags.ts (BFF)
# ==============================================================================
# AI_ENABLED=false                       # Master toggle para IA
# LOCAL_AI_ENABLED=true                  # IA local (Ollama)
# PREMIUM_AI_ENABLED=false               # IA paga (OpenAI)
# ENABLE_BANNER_WORKER=false             # Worker de banners
# PUBLIC_EMIT_LEGACY_IMAGE_PROXY=false   # Proxy legacy /uploads (auto: on em dev)
# REQUEST_AUDIT_LOGS_ENABLED=false       # Logs detalhados de HTTP
# SERVE_UPLOADS_STATIC=                  # Servir /uploads estático (auto: on em dev)
# DISABLE_REDIS=false                    # Desabilitar Redis (cache + filas)
# RUN_MIGRATIONS=false                   # Rodar migrations no boot
# RUN_WORKERS=false                      # Iniciar workers no boot
# E2E_MOCK_BACKEND=                      # Usar mock backend para E2E
