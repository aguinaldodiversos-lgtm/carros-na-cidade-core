# ==============================================================================
# .env.example — Carros na Cidade
# Copie para .env e ajuste os valores.
# ==============================================================================

# Server
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# ---------------------------------------------------------------------------
# Database (obrigatório)
# ---------------------------------------------------------------------------
# Dev local: docker compose -f docker-compose.test.yml up -d  (Postgres 15, porta 5433)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/carros_na_cidade_test

# Mesma URL usada por scripts de integração/e2e
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/carros_na_cidade_test

# Pool PostgreSQL (opcional)
PG_POOL_MAX=20
PG_IDLE_TIMEOUT_MS=30000
PG_CONN_TIMEOUT_MS=10000
PG_SLOW_QUERY_MS=800

# SSL — false para dev local, true em produção
PG_SSL_ENABLED=false
PG_SSL_REJECT_UNAUTHORIZED=true

# ---------------------------------------------------------------------------
# Auth (obrigatório)
# ---------------------------------------------------------------------------
JWT_SECRET=seu-jwt-secret-aqui
JWT_REFRESH_SECRET=seu-refresh-secret-aqui

# Frontend session cookie (obrigatório em produção)
AUTH_SESSION_SECRET=gere-um-segredo-longo-e-aleatorio-aqui

# ---------------------------------------------------------------------------
# Migrations e workers
# ---------------------------------------------------------------------------
# true = aplica migrations no boot; false = rode manualmente: npm run db:migrate
RUN_MIGRATIONS=true
RUN_WORKERS=false

# ---------------------------------------------------------------------------
# Redis (opcional — desabilitado por padrão em dev)
# ---------------------------------------------------------------------------
DISABLE_REDIS=true
# REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://127.0.0.1:4000

# FIPE (opcional)
# FIPE_API_KEY=SUA_CHAVE_AQUI

# Redes sociais (opcional — se vazio, rodapé não exibe links)
# NEXT_PUBLIC_SOCIAL_INSTAGRAM_URL=
# NEXT_PUBLIC_SOCIAL_FACEBOOK_URL=
# NEXT_PUBLIC_SOCIAL_LINKEDIN_URL=

# ---------------------------------------------------------------------------
# Smoke tests
# ---------------------------------------------------------------------------
BASE_URL=http://localhost:4000
SMOKE_TIMEOUT_MS=8000

# ---------------------------------------------------------------------------
# IA (opcional — docs/configuration/ai-environment.md)
# ---------------------------------------------------------------------------
# AI_ENABLED=false
# AI_MODE=local
# AI_LOCAL_URL=http://localhost:11434
# OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# Integrações externas (opcional)
# ---------------------------------------------------------------------------
# MP_ACCESS_TOKEN=
# MP_PUBLIC_KEY=
# RESEND_API_KEY=
# GOOGLE_PLACES_API_KEY=
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
